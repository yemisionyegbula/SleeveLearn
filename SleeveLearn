                    <div className="plan-action">
                      <span className="plan-icon" style={{ background: "var(--terra-l)", color: "var(--terra)" }}>✓</span>
                      <div style={{ fontSize: "0.83rem" }}><strong>Audit Low Gaps:</strong> Complete micro-modules for any skill recorded below intermediate thresholds.</div>
                    </div>
                    <div className="plan-action">
                      <span className="plan-icon" style={{ background: "var(--terra-l)", color: "var(--terra)" }}>✓</span>
                      <div style={{ fontSize: "0.83rem" }}><strong>Core Synthesis:</strong> Dedicate 45 minutes daily to your chosen technical track on Alison.</div>
                    </div>
                  </div>
                </div>

                <div className="plan-phase" style={{ "--dc": "var(--teal)" }}>
                  <div className="phase-head" style={{ color: "var(--teal)" }}>PHASE 2: Application Loops (Days 21–40)</div>
                  <div className="card">
                    <p style={{ fontSize: "0.85rem", color: "var(--ink2)", marginBottom: "1rem" }}>Translate conceptual tools directly into organizational framework models. Build active case exercises.</p>
                    <div className="plan-action">
                      <span className="plan-icon" style={{ background: "var(--teal-l)", color: "var(--teal)" }}>⚙</span>
                      <div style={{ fontSize: "0.83rem" }}><strong>Simulated Integration:</strong> Draft diagnostic workspace scripts based on performance analysis templates.</div>
                    </div>
                  </div>
                </div>

                <div className="plan-phase" style={{ "--dc": "var(--purple)" }}>
                  <div className="phase-head" style={{ color: "var(--purple)" }}>PHASE 3: Leadership & Expert Review (Days 41–60)</div>
                  <div className="card">
                    <p style={{ fontSize: "0.85rem", color: "var(--ink2)", marginBottom: "1rem" }}>Consolidate learning gains, map continuous resilience systems, and pursue expert validation milestones.</p>
                    <div className="plan-action">
                      <span className="plan-icon" style={{ background: "var(--purple-l)", color: "var(--purple)" }}>👑</span>
                      <div style={{ fontSize: "0.83rem" }}><strong>Peer Presentation:</strong> Deliver an internal capability sharing brief to scale structural workspace value.</div>
                    </div>
                  </div>
                </div>
              </div>

              {/* Dynamic Curated Micro Repository Sidebar */}
              <div>
                <h3 className="heading" style={{ fontSize: "1.1rem", marginBottom: "1rem" }}>Curated Learning Resources</h3>
                <div style={{ display: "flex", flexDirection: "column", gap: "1rem" }}>
                  {allSkills.slice(0, 5).map(skill => {
                    const skillResources = RESOURCES[skill] || DEFAULT_RESOURCES(skill);
                    return (
                      <div key={skill} style={{ borderBottom: "1px solid var(--parchment3)", paddingBottom: "1rem" }}>
                        <h4 style={{ fontSize: "0.8rem", textTransform: "uppercase", color: "var(--ink3)", marginBottom: "0.5rem" }}>{skill}</h4>
                        <div style={{ display: "flex", flexDirection: "column", gap: "0.5rem" }}>
                          {skillResources.map((res, i) => (
                            <a key={i} href={res.u} target="_blank" rel="noopener noreferrer" className="res-card" style={{ "--tc": "var(--teal)", padding: "0.75rem" }}>
                              <div style={{ fontSize: "0.82rem", fontWeight: "600" }}>
                                {TYPE_ICON[res.k] || "🔗"} {res.t}
                              </div>
                              <span style={{ fontSize: "0.68rem", fontWeight: "700", color: TYPE_COLOR[res.k] || "var(--ink3)" }}>{res.k.toUpperCase()}</span>
                            </a>
                          ))}
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          </div>
        )}

        {/* SCREEN 4: MENTORING COACHING BOT CONSOLE */}
        {screen === "coaching" && (
          <div className="section anim-in">
            <div style={{ marginBottom: "2rem" }}>
              <span className="eyebrow">Strategic Advisory Module</span>
              <h1 className="section-title">Upskilling Advisory Desk</h1>
              <p className="section-sub">Troubleshoot resource selection, request continuous structural framework design guidance, or discuss systemic deployment friction.</p>
            </div>

            <div className="card" style={{ display: "flex", flexDirection: "column", height: "460px", padding: "0" }}>
              {/* Message Feed Window */}
              <div style={{ flex: 1, padding: "1.5rem", overflowY: "auto", display: "flex", flexDirection: "column", gap: "1rem" }}>
                {chatLog.map((chat, idx) => (
                  <div key={idx} style={{ display: "flex", justifyContent: chat.r === "user" ? "flex-end" : "flex-start" }}>
                    <div className={`chat-bubble ${chat.r === "user" ? "user" : "bot"}`}>
                      {chat.m}
                    </div>
                  </div>
                ))}
                {isTyping && (
                  <div style={{ display: "flex", justifyContent: "flex-start" }}>
                    <div className="chat-bubble bot" style={{ display: "flex", gap: "4px", padding: "0.85rem 1.2rem" }}>
                      <span className="typing-dot"></span>
                      <span className="typing-dot"></span>
                      <span className="typing-dot"></span>
                    </div>
                  </div>
                )}
              </div>

              {/* Fixed Control Entry Console */}
              <form onSubmit={handleChatSend} style={{ display: "flex", gap: "0.5rem", padding: "1rem", borderTop: "1.5px solid var(--parchment3)", background: "var(--parchment2)" }}>
                <input type="text" className="input" placeholder="Ask about specific free courses, plan customization, or scaling frameworks..." value={chatInput} onChange={(e) => setChatInput(e.target.value)} />
                <button type="submit" className="btn btn-primary">Send</button>
              </form>
            </div>

            {/* Micro Badge Milestone Engine Showcase */}
            <div style={{ marginTop: "3rem" }}>
              <h2 className="section-title" style={{ fontSize: "1.2rem", marginBottom: "1.25rem" }}>Earned Milestones & Badges:</h2>
              <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(180px, 1fr))", gap: "1rem" }}>
                {REWARD_BADGES.map((b, idx) => {
                  const isEarned = idx === 0 || completedSkillsCount > idx * 2;
                  return (
                    <div key={b.id} className={`badge-card ${isEarned ? "earned" : "locked"}`}>
                      <span className="badge-icon">{b.icon}</span>
                      <div className="badge-name">{b.name}</div>
                      <div className="badge-desc">{b.desc}</div>
                    </div>
                  );
                })}
              </div>
            </div>

            {/* Danger Zone Utilities Partition */}
            <div style={{ marginTop: "4rem", paddingTop: "2rem", borderTop: "1.5px dashed var(--parchment3)", textAlign: "center" }}>
              <button className="btn btn-ghost" style={{ color: "var(--terra)" }} onClick={resetProgress}>
                ⚠ Reset Profile Progress Data
              </button>
            </div>
          </div>
        )}

      </main>
    </div>
  );
}
