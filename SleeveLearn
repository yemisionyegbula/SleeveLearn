  // --- Initialize Application Assets ---
  useEffect(() => {
    loadGA();
    loadClarity();
    const styleEl = document.createElement("style");
    styleEl.innerHTML = STYLES;
    document.head.appendChild(styleEl);
    return () => styleEl.remove();
  }, []);

  // --- Auto-Save and Navigation Progress Tracker ---
  const navigate = useCallback((targetScreen) => {
    setScreen(targetScreen);
    localStorage.setItem("sl_screen", targetScreen);
    trackPage(targetScreen);
    window.scrollTo({ top: 0 });
  }, []);

  useEffect(() => {
    localStorage.setItem("sl_role", role);
    localStorage.setItem("sl_skills_curr", JSON.stringify(skillsCurrent));
    localStorage.setItem("sl_skills_targ", JSON.stringify(skillsTarget));
    localStorage.setItem("sl_streak", streak.toString());
  }, [role, skillsCurrent, skillsTarget, streak]);

  const triggerToast = (msg) => {
    setToast(msg);
    setTimeout(() => setToast(""), 3000);
  };

  // --- Calculate Competency Architecture Data Metrics ---
  const currentCompetencies = ROLE_COMPETENCIES[role] || [];
  
  useEffect(() => {
    if (currentCompetencies.length > 0 && !activeTab) {
      setActiveTab(currentCompetencies[0].id);
    }
  }, [currentCompetencies, activeTab]);

  const allSkills = currentCompetencies.flatMap(c => c.skills);
  const totalSkillsCount = allSkills.length;
  
  const completedSkillsCount = allSkills.filter(s => {
    const curr = skillsCurrent[s] || 0;
    const targ = skillsTarget[s] || 0;
    return curr > 0 && curr >= targ;
  }).length;

  const progressPercent = totalSkillsCount > 0 ? Math.round((completedSkillsCount / totalSkillsCount) * 100) : 0;

  // --- Action Handlers ---
  const updateLevel = (skill, type, levelIndex) => {
    if (type === "current") {
      setSkillsCurrent(prev => ({ ...prev, [skill]: levelIndex }));
      trackEvent("set_current_level", skill, LEVELS[levelIndex]);
    } else {
      setSkillsTarget(prev => ({ ...prev, [skill]: levelIndex }));
      trackEvent("set_target_level", skill, LEVELS[levelIndex]);
    }
  };

  const handleChatSend = async (e) => {
    e.preventDefault();
    if (!chatInput.trim()) return;

    const userMsg = chatInput.trim();
    setChatLog(prev => [...prev, { r: "user", m: userMsg }]);
    setChatInput("");
    setIsTyping(true);
    trackEvent("chat_message_sent", "coaching_bot", userMsg.slice(0, 30));

    // High fidelity simulator mimicking structured advisory mentoring
    setTimeout(() => {
      let response = "That is a vital focus area for sustainable productivity. I suggest checking Alison.com for dedicated operational strategy tracks, or using short, high-impact YouTube tutorials to map your tactical daily micro-habits.";
      
      if (userMsg.toLowerCase().includes("plan") || userMsg.toLowerCase().includes("60")) {
        response = "Your 60-day learning roadmap balances foundational capability baseline steps (Days 1-20) with applied field case studies (Days 21-40) and expert review matrices (Days 41-60). Focus on one strategic block at a time to retain structural mastery.";
      } else if (userMsg.toLowerCase().includes("resilience") || userMsg.toLowerCase().includes("culture")) {
        response = "Building continuous learning ecosystems demands localized, structural behavioral loops. Pair your upskilling pathways directly with micro-incentives like digital badges to enhance continuous resilience.";
      }

      setChatLog(prev => [...prev, { r: "bot", m: response }]);
      setIsTyping(false);
    }, 1100);
  };

  const resetProgress = () => {
    if (window.confirm("Are you sure you want to restart your development profile?")) {
      localStorage.clear();
      setRole("");
      setSkillsCurrent({});
      setSkillsTarget({});
      setStreak(3);
      navigate("welcome");
